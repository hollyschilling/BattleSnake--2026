{
    "name": "battlesnake/snake",
    "description": "BattleSnake server (Standard ruleset, apiversion 1).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S 127.0.0.1:8080 -t public"
    },
    "minimum-stability": "stable"
}
